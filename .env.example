# ResolveHub Docker Compose Environment
# Copy to .env and fill in production values

# Auth
JWT_SECRET=change-this-to-a-strong-random-secret-key
JWT_EXPIRES=7d

# AI Categorization (Gemini)
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TIMEOUT_MS=8000
GEMINI_RETRIES=2

# EvalForge service authentication (shared secret for eval endpoint)
EVAL_SERVICE_SECRET=change-this-eval-secret

# CORS (comma-separated allowed origins)
CORS_ORIGINS=https://your-frontend.vercel.app,http://localhost:5173

# Rate limiting
RATE_LIMIT_MAX=300

# Logging
LOG_LEVEL=info

# Admin seed (set to auto-create admin on first run)
SEED_ADMIN=true
ADMIN_EMAIL=admin@resolvehub.local
ADMIN_PASSWORD=change-this-admin-password
ADMIN_NAME=System Admin
